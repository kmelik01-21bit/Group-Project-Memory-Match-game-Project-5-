import java.util.Scanner;

public class MemoryMatchGame {
    public static void main(String[] args) {

        //Creating New Scanner
        Scanner sc = new Scanner(System.in);

        //Creating an array for the cards
        int[] cards = new int[16];

        //Creating the cards and converting into pairs
        for (int i = 0; i < 16; i++) {
            cards[i] = (i + 1);
            if (Integer.parseInt(String.valueOf(cards[i])) % 2 == 0) {
                cards[i] = cards[i - 1];
            }
        }

        //Print check
        for (int i = 0; i < cards.length; i++) {
            System.out.print(cards[i] + " ");
        }

        //Rest of the code bellow


        
        
        
        //Close Scanner
        sc.close();
    }
}
