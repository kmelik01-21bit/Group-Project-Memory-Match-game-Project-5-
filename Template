import java.util.IllegalFormatCodePointException;
import java.util.Random;
import java.util.Scanner;
import java.util.Arrays;

public class MemoryMatchGame {

    //Creating an array for the cards
    static int[] cards = new int[16];

    static int[] rowA = new int[4];
    static int[] rowB = new int[4];
    static int[] rowC = new int[4];
    static int[] rowD = new int[4];

    public static void main(String[] args) {

        //Creating New Scanner + Random Object
        Scanner sc = new Scanner(System.in);
        Random rng = new Random();

        //Creating the cards and converting into pairs
        for (int i = 0; i < 16; i++) {
            cards[i] = (i + 1);
            if (Integer.parseInt(String.valueOf(cards[i])) % 2 == 0) {
                cards[i] = cards[i - 1];
            }
        }

        //Print check
        System.out.println("CARDS");
        System.out.println(Arrays.toString(cards));

        //Shuffling
        shuffleCards(cards);

        //Print check
        System.out.println("\nSHUFFLED DECK");
        System.out.println(Arrays.toString(cards));

        //Grid layout
        //Setting up layout for cards
        System.arraycopy(cards, 0, rowA, 0, 4);
        System.arraycopy(cards, 4, rowB, 0, 4);
        System.arraycopy(cards, 8, rowC, 0, 4);
        System.arraycopy(cards, 12, rowD, 0, 4);

        //Print Check
        System.out.println(Arrays.toString(rowA) + Arrays.toString(rowB) + Arrays.toString(rowC) + Arrays.toString(rowD));

        //Starting grid
        int matches = 0;
        int moves = 0;

        while (matches < 8) {
            System.out.println("""
                [1] [2] [3] [4]

            [A] [?] [?] [?] [?]

            [B] [?] [?] [?] [?]

            [C] [?] [?] [?] [?]

            [D] [?] [?] [?] [?]

            """);
            System.out.println("Pick 2 matching Cards (ex: A2 and B4)");
            System.out.print("Card 1: ");
            String choice1 = sc.nextLine().toUpperCase();

            System.out.print("Card 2: ");
            String choice2 = sc.nextLine().toUpperCase();

            boolean check = cardCheck(choice1, choice2);

            if (check) {
                System.out.println("Pair found!");
                matches++;
            } else {
                System.out.println("Wrong pair! Try again!");
            }
            moves++;
        }

        System.out.println("You found all matches! You took " + moves + " moves!");
        
        //rest of the code will be added below





        //Close Scanner
        sc.close();
    }

    //Check for the value of both chosen positions and compare the values to check if they match
    public static boolean cardCheck (String choice1, String choice2) {
        //Creating temp values
        int i = 0;
        int j = 0;

        //Checking position of each choice
        if (choice1.contains("A")) {
            for (char c : choice1.toCharArray()) {
                if (c == choice1.charAt(choice1.length() - 1)) {
                    i = rowA[choice1.charAt(choice1.length() - 1)];
                    break;
                }
            }
        } else if (choice1.contains("B")) {
            for (char c : choice1.toCharArray()) {
                if (c == choice1.charAt(choice1.length() - 1)) {
                    i = rowB[choice1.charAt(choice1.length() - 1)];
                    break;
                }
            }
        } else if (choice1.contains("C")) {
            for (char c : choice1.toCharArray()) {
                if (c == choice1.charAt(choice1.length() - 1)) {
                    i = rowC[choice1.charAt(choice1.length() - 1)];
                    break;
                }
            }
        } else if (choice1.contains("D")) {
            for (char c : choice1.toCharArray()) {
                if (c == choice1.charAt(choice1.length() - 1)) {
                    i = rowD[choice1.charAt(choice1.length() - 1)];
                    break;
                }
            }
        } else {
            System.out.println("INVALID CARD CHOICE FOR CARD 1");
        }

        if (choice2.contains("A")) {
            for (char c : choice2.toCharArray()) {
                if (c == choice2.charAt(choice2.length() - 1)) {
                    j = rowA[choice2.charAt(choice2.length() - 1)];
                    break;
                }
            }
        } else if (choice2.contains("B")) {
            for (char c : choice2.toCharArray()) {
                if (c == choice2.charAt(choice2.length() - 1)) {
                    j = rowB[choice2.charAt(choice2.length() - 1)];
                    break;
                }
            }
        } else if (choice2.contains("C")) {
            for (char c : choice2.toCharArray()) {
                if (c == choice2.charAt(choice2.length() - 1)) {
                    j = rowC[choice2.charAt(choice2.length() - 1)];
                    break;
                }
            }
        } else if (choice2.contains("D")) {
            for (char c : choice2.toCharArray()) {
                if (c == choice2.charAt(choice2.length() - 1)) {
                    j = rowD[choice2.charAt(choice2.length() - 1)];
                    break;
                }
            }
        } else {
            System.out.println("INVALID CARD CHOICE FOR CARD 2");
        }

        //Compare the two values and exclude any zeros
        if (i == 0 || j == 0) {
            System.out.println("INVALID CARD(S).");
            return false;
        } else {
            if (i == j) {
                return true;
            } else {
                return false;
            }
        }
    }

    public static void shuffleCards (int[] array) {
        //Creating New Random Object
        Random rng = new Random();

        for (int i = array.length - 1; i > 0; i--) {
            int j = rng.nextInt(i + 1);

            int temp = array[i];
            array[i] = array[j];
            array[j] = temp;
        }
    }
}
